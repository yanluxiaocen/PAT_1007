#include<stdio.h>

int main() {
	int n;
	scanf("%d", &n);

	int prime[317];
	int k = 0;
	for (int i = 0; i < n; i++)
	{
		if (n <= 1) continue;
		if (n == 2) {
			prime[k++] = n;
			continue;
		}
		else if (n % 2 == 0) continue;

		for (int j = 3; j * j <= i; j += 2)
			if (i % j == 0) continue;
		prime[k++] = n;
	}

	int result = 0;
	for (int i = 1; i < k; i++)
		if (prime[i] - prime[i - 1] == 2)
			result++;
	printf("%d", result);
}
