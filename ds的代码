#include <stdio.h>
#include <stdbool.h>
#include <math.h>

// 判断是否为素数
bool isPrime(int num) {
    if (num <= 1) return false;
    if (num == 2) return true;
    if (num % 2 == 0) return false;
    
    int limit = (int)sqrt(num);
    for (int i = 3; i <= limit; i += 2) {
        if (num % i == 0) return false;
    }
    return true;
}

int main() {
    int n;
    printf("请输入范围 n：");
    scanf("%d", &n);
    
    // 先找出 n 以内的所有素数
    int prime[10000];  // 假设 n 不超过 100000，素数个数够用
    int k = 0;
    
    for (int i = 2; i <= n; i++) {
        if (isPrime(i)) {
            prime[k++] = i;
        }
    }
    
    // 统计孪生素数对
    int result = 0;
    for (int i = 1; i < k; i++) {
        if (prime[i] - prime[i - 1] == 2) {
            result++;
        }
    }
    
    printf("%d", result);
    return 0;
}
